# App General Settings
APP_NAME=async-workflow-engine
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database Connection Details
# Probed at startup. If unreachable, the engine falls back to in-memory storage.
# Use host.docker.internal when connecting from containers, or localhost from host.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
REDIS_URL=redis://localhost:6379/0

# Celery (background workflow dispatch)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Set to 1/true to route all /workflows/run requests through Celery by default.
# Requires a running Celery worker (`make worker`) + Redis. Leave unset for the
# default synchronous, broker-free path.
WORKFLOW_ASYNC=

# External APIs (optional — enable the real LLM classification path when set)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GITHUB_TOKEN=your-github-token
